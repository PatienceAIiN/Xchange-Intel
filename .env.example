# ===== App =====
APP_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=https://your-service.onrender.com

# ===== Auth =====
SECRET_KEY=change-me-to-a-64-char-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ===== Database (Neon Postgres — primary, app stores everything here) =====
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ===== Source DB to import existing startups from (read-only, optional) =====
# startups only, deduped, mapped to our schema. Leave blank to disable import.
SOURCE_DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ===== Search providers (all free) =====
DATAGOV_API_KEY=your-data-gov-in-api-key
DATAGOV_API_URL=https://api.data.gov.in/resource/
DATAGOV_MCA_RESOURCE=4dbe5667-7b6b-41d7-82af-211562424d9a
SERPAPI_KEY=
SEARXNG_URL=https://searx.be
USE_PAID_SEARCH=false

# ===== LLM (Groq — free tier) =====
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ===== Matching / rate limiting =====
MATCH_CONFIDENCE_THRESHOLD=0.75
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_SCRAPER=20

# ===== Email (Brevo) + autonomous pipeline =====
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=info@patienceai.in
BREVO_SENDER_NAME=Nexus Exchange
COMPLETION_EMAIL=harsh@patienceai.in
SITE_URL=https://your-service.onrender.com
AUTO_PROCESS=true          # auto-run import->contact-fill on boot (Render)
MCA_IMPORT_TARGET=50000
